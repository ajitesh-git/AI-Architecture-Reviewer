{
  "name": "ai-architecture-reviewer",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source architecture review tool that analyzes uploaded solutions, detects anti-patterns, suggests improvements, and generates scorecards.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/web",
    "dev:api": "npm run dev -w apps/api",
    "build": "npm run build -w apps/web",
    "preview": "npm run preview -w apps/web",
    "test": "npm test --workspaces --if-present",
    "analyze": "npm run analyze -w apps/cli --"
  },
  "engines": {
    "node": ">=20"
  }
}
