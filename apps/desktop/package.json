{
  "name": "@ai-architecture-reviewer/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "author": "AI Architecture Reviewer contributors",
  "description": "Electron desktop shell for AI Architecture Reviewer.",
  "main": "src/main.js",
  "scripts": {
    "dev": "electron src/main.js",
    "start": "electron src/main.js",
    "dist": "electron-builder --win",
    "pack": "electron-builder --dir"
  },
  "dependencies": {
    "@ai-architecture-reviewer/api": "file:../api"
  },
  "devDependencies": {
    "electron": "42.4.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.aiarchreviewer.desktop",
    "productName": "AI Architecture Reviewer",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "../web/dist/**/*",
      "../api/src/**/*",
      "../../packages/analyzer-core/src/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
